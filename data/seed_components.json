    "code": "<section class=\"relative bg-neutral-950 text-white py-32 px-6 flex flex-col items-center justify-center text-center overflow-hidden\">\n  <div class=\"absolute inset-0 bg-[radial-gradient(circle_at_center,rgba(99,102,241,0.15),transparent_60%)]\"></div>\n  <div class=\"relative max-w-3xl z-10\">\n    <span class=\"bg-indigo-500/10 border border-indigo-500/20 text-indigo-400 text-xs px-3 py-1 rounded-full uppercase tracking-wider font-semibold\">Introducing OpenBlocks</span>\n    <h1 class=\"text-4xl md:text-6xl font-extrabold tracking-tight mt-6 leading-tight bg-gradient-to-r from-white via-indigo-200 to-indigo-400 bg-clip-text text-transparent\">Assemble Websites in Seconds, Not Hours</h1>\n    <p class=\"text-neutral-400 text-lg md:text-xl mt-6 max-w-xl mx-auto leading-relaxed\">The local-first component server that empowers AI agents to build stunning user interfaces from curated, production-ready blocks.</p>\n    <div class=\"flex flex-col sm:flex-row items-center justify-center space-y-4 sm:space-y-0 sm:space-x-4 mt-10\">\n      <a href=\"#\" class=\"bg-indigo-600 hover:bg-indigo-500 text-white font-medium px-6 py-3 rounded-lg shadow-lg shadow-indigo-600/25 transition w-full sm:w-auto\">Get Started</a>\n      <a href=\"#\" class=\"bg-neutral-900 hover:bg-neutral-800 border border-neutral-800 text-neutral-300 font-medium px-6 py-3 rounded-lg transition w-full sm:w-auto\">Read Docs</a>\n    </div>\n  </div>\n</section>",
